# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gpa_user:CHANGE_ME@localhost:5432/gpa_erp

# ─── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=GPA-ERP
APP_VERSION=5.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Super-Admin seed ────────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@gpa.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=System Administrator

# ─── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
